{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NPU Companion",
  "version": "0.1.0",
  "identifier": "com.npuproject.companion",

  "build": {
    "frontendDist": "../app_shell",
    "devUrl": "http://127.0.0.1:5173"
  },

  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "NPU Companion",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:8000 ipc: http://ipc.localhost"
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
