# Build artifacts
build/
dist/
bin/

# Rust/Cargo build output
src-tauri/target/

# Python
venv/
.venv/
__pycache__/
*.pyc

# OpenVINO / binaries
*.dll
*.exe
*.bin
*.obj
*.lib
*.ilk
*.pdb
*.exp

# Models (too large for git)
models/

# NPU cache files
npu_cache/

# Marketing site (npm install / Vite); never commit dependencies
site/node_modules/
*.tsbuildinfo

# Local benchmark / probe output (script + app shell feature compare)
benchmark_outputs/

# Root distribution zips (build in CI or locally; never commit large binaries)
/*.zip
loomis-dist-*.zip
acoulm-dist-*.zip

# OS / editor
.vs/
.vscode/
.DS_Store
Thumbs.db
*.vcxproj.user

# Log files
runlog.txt
debug_init.txt
output.txt
*.log
runlogs/

# Runtime-generated metrics
metrics.ndjson
telemetry/

# Registry JSON is machine-specific (paths, selections). Commit only *.example.json templates.
registry/*.json
!registry/*.example.json
*.bak

# OpenWebUI runtime secret (auto-generated, do not commit)
.webui_secret_key

# Odd cache / probe blobs
*.blob

# GPU cache (large auto-generated inference cache)
gpu_cache/

# CMake
CMakeCache.txt
CMakeFiles/

# Secret scanning local artifacts
gitleaks-report*.json
gitleaks-report*.sarif
*.gitleaks.json
*.gitleaks.sarif

# Local export / SBOM output (user-generated)
export/
sbom/
